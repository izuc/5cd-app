# Build artifacts
**/node_modules/
**/dist/
**/build/
**/*.tsbuildinfo

# Python
**/__pycache__/
**/*.pyc
**/.venv/
**/venv/

# Model weights (downloaded via download_model.py)
ai-service/models/*
!ai-service/models/.gitkeep
# FLUX.2 reference repo cloned by the installer (reference only; runtime uses diffusers)
ai-service/flux2/

# PHP
backend/vendor/

# Environment & secrets
**/.env
**/.env.local

# User-generated content
uploads/projects/
backend/uploads/projects/

# Logs and OS junk
*.log
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# temp vectoriser test harness (dev only)
frontend/vectest_harness.*
