# ---- Model paths -------------------------------------------------------
# Folder where model files live (config.json, tokenizer*, *.gguf)
MODELS_DIR=./models

# HF repo to pull tokenizer + config from (the GGUF repo doesn't have them).
TOKENIZER_REPO=sensenova/SenseNova-U1-8B-MoT

# HF repo + filename for the GGUF weights.
GGUF_REPO=smthem/SenseNova-U1-8B-MoT-Merger-gguf
GGUF_FILE=SenseNova-U1-8B-MoT-Infographic-Q6_K.gguf

# ---- Inference settings -----------------------------------------------
# Where to run the diffusion path. Falls back to placeholder mode if CUDA
# is missing or model load fails.
DEVICE=cuda
DTYPE=bfloat16

# The shipped model is the Infographic (base, non-distilled) variant, which needs
# ~25 steps at cfg 4.0. For the fast 8-step distilled model instead, use
# GGUF_FILE=SenseNova-U1-8B-MoT-8step-Q4_K_S.gguf with DEFAULT_STEPS=8 / cfg 1.0.
DEFAULT_STEPS=25
DEFAULT_CFG_SCALE=4.0
CFG_NORM=none  # none | global | channel | cfg_zero_star
DEFAULT_TIMESTEP_SHIFT=3.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024

# Reasoning ("think") pass before image generation. 0 = off (fast, ~20s/img);
# 1 = on (~3x slower, better prompt adherence). Per-request `think` overrides.
THINK_MODE=0

# Layer streaming wrapper prefetch count (set to 0 to disable streaming if
# you have plenty of VRAM).
PREFETCH_COUNT=2

# ---- Server ----------------------------------------------------------
HOST=127.0.0.1
PORT=8090
MAX_QUEUE=20
JOB_TTL=600
