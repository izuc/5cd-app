# ---- 5cd AI image worker — FLUX.2-klein-4B ----------------------------
# One model for everything: text-to-image, image-to-image (edits) and AI upscaling.
# Quantised to fit a single <24GB card (GGUF transformer + 4-bit text encoder;
# with the Q4_K_M default ~6.8GB resident, ~11.6GB peak at 1024px).

# ---- Models -----------------------------------------------------------
MODELS_DIR=./models
# Base diffusers repo: supplies VAE, scheduler, tokenizer + the text-encoder weights/configs.
BASE_REPO=black-forest-labs/FLUX.2-klein-4B
# GGUF transformer (relative to MODELS_DIR). Q4_K_M (~2.6GB) is the smallest with good
# quality; bump to Q5_K_M / Q6_K for a touch more fidelity. From unsloth/FLUX.2-klein-4B-GGUF.
GGUF_FILE=flux2-gguf/flux-2-klein-4b-Q4_K_M.gguf
# Quantise the Qwen3 text encoder to 4-bit (nf4): ~2.5GB vs ~8GB bf16. Set 0 for bf16.
TEXT_ENCODER_4BIT=1
# AI upscaler (spandrel) for the vectoriser. 4x model; output capped to UPSCALE_MAX_DIM.
UPSCALER_FILE=upscaler/4x-UltraSharp.safetensors
UPSCALE_MAX_DIM=2048
UPSCALE_TILE=512

# FLUX.2-klein is ungated. A token is only needed if HF rate-limits anonymous pulls.
HF_TOKEN=

# ---- Inference --------------------------------------------------------
DEVICE=cuda
DTYPE=bfloat16
DEFAULT_STEPS=4        # klein is step-distilled
GUIDANCE_SCALE=4.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
# klein is tuned for ~1MP; long side capped to this (requests above are scaled down).
MAX_SIDE=1024
# Set 1 to CPU-offload and fit in ~16GB (slower). 0 keeps everything on-GPU.
ENABLE_CPU_OFFLOAD=0
# Which physical GPU to use (empty = all visible / cuda:0).
GPU_INDEX=

# ---- Server -----------------------------------------------------------
HOST=127.0.0.1
PORT=8090
MAX_QUEUE=20
JOB_TTL=600
