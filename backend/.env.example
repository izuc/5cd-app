DB_HOST=localhost
DB_NAME=5cd_single
DB_USER=root
DB_PASS=
DB_PORT=3306

JWT_SECRET=replace_me_with_a_random_64_char_string
JWT_EXPIRY=604800

APP_ENV=development
FRONTEND_URL=http://localhost:5180
AI_SERVICE_URL=http://127.0.0.1:8090
UPLOADS_DIR=../uploads

# Optional: route text-to-image to the alternate engine worker (alt-engine-service:
# FLUX.2-klein or Ideogram 4) instead of SenseNova. Off by default; falls back to
# SenseNova if the worker is unreachable. Reference-guided generation stays on
# SenseNova. ALT_ENGINE_EDITS=true also routes edits there, but ONLY if the running
# engine supports image-to-image (FLUX does; Ideogram is t2i-only and will fall back).
ALT_ENGINE_ENABLED=false
ALT_ENGINE_EDITS=false
ALT_ENGINE_SERVICE_URL=http://127.0.0.1:8091
