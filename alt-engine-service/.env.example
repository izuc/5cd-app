# ---- Optional alternate image engine (OFF unless backend enables it) --------
# Used only when the backend has ALT_ENGINE_ENABLED=true. Serves text-to-image
# (and, for engines that support i2i, edits) as a drop-in for the SenseNova worker.

# Which engine to run:
#   flux      black-forest-labs/FLUX.2-klein  (Apache-2.0, ungated, ~4 steps,
#             text-to-image AND image editing). Recommended.
#   ideogram  ideogram-ai/ideogram-4-nf4-diffusers + TurboTime LoRA
#             (GATED + NON-COMMERCIAL; needs HF_TOKEN; text-to-image only).
ENGINE=flux

# ---- Models -----------------------------------------------------------
MODELS_DIR=./models
# Override the engine's default repo if you want. Empty = engine default
# (flux -> black-forest-labs/FLUX.2-klein-4B bf16; ideogram -> ...-nf4-diffusers).
# NOTE: the FLUX.2-klein-4b-fp8 repo is a single-file checkpoint with no
# model_index.json, so it can't be loaded via from_pretrained here — use the bf16
# build (default) or a diffusers-format quant.
MODEL_REPO=
# LoRA repo (ideogram uses the TurboTime 8-step LoRA by default; flux needs none).
# LORA_REPO=
LORA_WEIGHT=1.0

# Needed ONLY for the gated Ideogram engine. Accept the license on the HF model
# page while logged in, then put a token from https://huggingface.co/settings/tokens
HF_TOKEN=

# ---- Inference --------------------------------------------------------
DEVICE=cuda
DTYPE=bfloat16
# Leave blank to use the engine default (flux=4 steps/guidance 4.0; ideogram=8/1.0).
# DEFAULT_STEPS=
# GUIDANCE_SCALE=
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
# Set 1 to offload to CPU and fit in ~16GB VRAM (slower). 0 keeps it on-GPU.
ENABLE_CPU_OFFLOAD=0

# Which physical GPU. Default GPU 1 keeps this off the SenseNova worker (GPU 0).
GPU_INDEX=1

# ---- Server -----------------------------------------------------------
HOST=127.0.0.1
PORT=8091
MAX_QUEUE=20
JOB_TTL=600
